generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int              @id @default(autoincrement())
  email        String           @unique
  passwordHash String
  roleType     String           @default("simple")
  locale       String           @default("el")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  vehicles         Vehicle[]
  fixedCosts       FixedCost[]
  vehicleProfiles  VehicleProfile[]
  costProfiles     CostProfile[]
  platformProfiles PlatformProfile[]
  expenseCategories ExpenseCategory[]
  expenses         Expense[]
  appSettings      AppSettings?
  billingProfile   BillingProfile?
  shifts           Shift[]
}

model Vehicle {
  id                  Int      @id @default(autoincrement())
  userId              Int
  vehicleType         String
  fuelType            String
  consumptionPer100Km Float
  fuelPrice           Float
  maintenancePerKm    Float
  tiresPerKm          Float
  depreciationPerKm   Float
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VehicleProfile {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  vehicleType             String
  fuelType                String
  fuelPricePerLiter       Decimal  @default(0) @db.Decimal(10, 2)
  fuelConsumptionPer100Km Decimal  @default(0) @db.Decimal(10, 2)
  maintenanceCostPerKm    Decimal  @default(0) @db.Decimal(10, 4)
  tiresCostPerKm          Decimal  @default(0) @db.Decimal(10, 4)
  depreciationCostPerKm   Decimal  @default(0) @db.Decimal(10, 4)
  routineServiceIntervalKm Decimal? @db.Decimal(10, 2)
  routineServiceCost      Decimal? @db.Decimal(10, 2)
  majorServiceIntervalKm  Decimal? @db.Decimal(10, 2)
  majorServiceCost        Decimal? @db.Decimal(10, 2)
  tireReplacementIntervalKm Decimal? @db.Decimal(10, 2)
  tireReplacementCost     Decimal? @db.Decimal(10, 2)
  purchasePrice           Decimal? @db.Decimal(10, 2)
  resaleValue             Decimal? @db.Decimal(10, 2)
  expectedLifecycleKm     Decimal? @db.Decimal(10, 2)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FixedCost {
  id                Int      @id @default(autoincrement())
  userId            Int
  insuranceMonthly  Float    @default(0)
  phoneMonthly      Float    @default(0)
  accountantMonthly Float    @default(0)
  roadTaxMonthly    Float    @default(0)
  kteoMonthly       Float    @default(0)
  otherMonthly      Float    @default(0)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CostProfile {
  id                Int      @id @default(autoincrement())
  userId            Int
  insuranceMonthly  Decimal  @default(0) @db.Decimal(10, 2)
  phoneMonthly      Decimal  @default(0) @db.Decimal(10, 2)
  accountantMonthly Decimal  @default(0) @db.Decimal(10, 2)
  roadTaxMonthly    Decimal  @default(0) @db.Decimal(10, 2)
  kteoMonthly       Decimal  @default(0) @db.Decimal(10, 2)
  otherMonthly      Decimal  @default(0) @db.Decimal(10, 2)
  dailyFixedCost    Decimal? @db.Decimal(10, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlatformProfile {
  id             Int      @id @default(autoincrement())
  userId         Int
  platformKey    String
  feePercent     Decimal? @db.Decimal(5, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id            Int      @id @default(autoincrement())
  userId        Int
  name          String
  scope         String   @default("business")
  cadence       String   @default("monthly")
  defaultAmount Decimal  @default(0) @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]
}

model Expense {
  id          Int      @id @default(autoincrement())
  userId      Int
  categoryId  Int?
  date        DateTime
  category    String
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenseCategory ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model AppSettings {
  id                       Int      @id @default(autoincrement())
  userId                   Int      @unique
  fuelPricePerLiter        Decimal? @db.Decimal(10, 2)
  fuelConsumptionPer100Km  Decimal? @db.Decimal(10, 2)
  maintenanceCostPerKm     Decimal? @db.Decimal(10, 4)
  depreciationCostPerKm    Decimal? @db.Decimal(10, 4)
  dailyFixedCost           Decimal? @db.Decimal(10, 2)
  platformFeePercent       Decimal  @default(0) @db.Decimal(5, 2)
  taxReservePercent        Decimal  @default(0) @db.Decimal(5, 2)
  currency                 String   @default("EUR")
  timezone                 String   @default("Europe/Athens")
  locale                   String   @default("el")
  preferredDashboardPeriod String   @default("week")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillingProfile {
  id                            Int       @id @default(autoincrement())
  userId                        Int       @unique
  planType                      String    @default("free")
  status                        String    @default("inactive")
  billingInterval               String?
  priceAmount                   Decimal?  @db.Decimal(10, 2)
  currency                      String    @default("EUR")
  paymentProvider               String?
  paymentProviderCustomerId     String?
  paymentProviderSubscriptionId String?
  currentPeriodEndsAt           DateTime?
  lifetimeAccessGrantedAt       DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([planType, status])
}

model Shift {
  id               Int      @id @default(autoincrement())
  userId           Int
  date             DateTime
  shiftDate        DateTime?
  startTime        String?
  endTime          String?
  platform         String
  area             String
  hours            Float
  hoursWorked      Float?
  ordersCount      Int
  ordersCompleted  Int?
  kilometers       Float
  kilometersDriven Float?
  platformEarnings Float
  baseEarnings     Decimal? @db.Decimal(10, 2)
  tipsCard         Float    @default(0)
  tipsCash         Float    @default(0)
  tipsAmount       Decimal? @db.Decimal(10, 2)
  bonus            Float    @default(0)
  bonusAmount      Decimal? @db.Decimal(10, 2)
  fuelExpenseDirect Decimal? @db.Decimal(10, 2)
  tollsOrParking   Decimal? @default(0) @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
